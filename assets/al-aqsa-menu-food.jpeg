/* Popup Styles */
.popup-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999999;
  opacity: 0;
  pointer-events: none;
  transition: 0.3s;
}
 
.popup-container.active {
  opacity: 1;
  pointer-events: auto;
}
 
.popup-box {
  background: #fff;
  padding: 25px;
  width: 350px;
  border-radius: 8px;
  text-align: center;
  position: relative;
  animation: fadeIn 0.4s ease;
}
 
.popup-btn {
  display: inline-block;
  background: #0073aa;
  color: #fff;
  padding: 10px 18px;
  border-radius: 5px;
  text-decoration: none;
  margin-top: 10px;
}
 
.popup-close {
  position: absolute;
  top: 8px;
  right: 10px;
  color: #333;
  background: transparent;
  border: none;
  font-size: 24px;
  cursor: pointer;
}
 
@keyframes fadeIn {
  from { transform: translateY(-20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
</style>
<!-- end Simple Custom CSS and JS -->
